      "memory_count": 12,
      "memories": [
        {
          "memory_id": "r001",
          "scene_id": "4",
          "scene_order": 5,
          "scene_title": "四 惊艳",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_1e9f29aa2757a0e7"
          ],
          "source_memory_refs": [],
          "memory_text": "我穿着浅橙色的袍子走出来，王妈妈让我拜老师，我就跪下去叫了一声‘老师’，声音有点发颤，看见何公子慌得直摆手，还打翻了酒杯。",
          "grounded_facts": [
            "乐娘身穿浅橙色袍服从内室走出",
            "在王妈催促下向何云青跪拜行礼",
            "娇声称呼何云青为‘老师’",
            "何云青受惊起身避让并打翻酒杯"
          ],
          "tags": [
            "初次见面",
            "行礼",
            "视觉印象",
            "紧张"
          ]
        },
        {
          "memory_id": "r002",
          "scene_id": "4",
          "scene_order": 5,
          "scene_title": "四 惊艳",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_1e9f29aa2757a0e7"
          ],
          "source_memory_refs": [],
          "memory_text": "我蹲下帮他擦衣服，手帕轻轻擦过他的袍角，低头说‘对不起，何老师’，听见自己的声音像泉水一样清脆，他却慌得直说是我不好。",
          "grounded_facts": [
            "乐娘掏出手帕为何云青擦拭溅酒的袍服",
            "低头轻声道歉",
            "声音被描述为清脆如山谷流泉",
            "何云青回应时语无伦次"
          ],
          "tags": [
            "近距离接触",
            "声音印象",
            "柔声致歉",
            "情感波动"
          ]
        },
        {
          "memory_id": "r003",
          "scene_id": "5",
          "scene_order": 6,
          "scene_title": "五 战鼓",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_4355694e5592ad7b"
          ],
          "source_memory_refs": [],
          "memory_text": "我敲响那面毡鼓，鼓声低哑沉闷，像战鼓一样层层叠叠地压过去，那个喇嘛站都站不稳，最后只能转身逃走。",
          "grounded_facts": [
            "乐娘接过王妈递来的毡鼓并开始击鼓， 鼓声响起后喇嘛双脚浮动、神情凄凉，最终逃走， 乐娘目睹喇嘛被鼓声逼退的过程"
          ],
          "tags": [
            "鼓声击退喇嘛",
            "权力展示",
            "神秘力量"
          ]
        },
        {
          "memory_id": "r004",
          "scene_id": "5",
          "scene_order": 6,
          "scene_title": "五 战鼓",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_4355694e5592ad7b"
          ],
          "source_memory_refs": [],
          "memory_text": "我一边打鼓一边给他倒酒，他眼神迷乱，嘴里含糊地喊着好，最后头一歪就倒下了，我伸手扶住他，他知道是他该倒的时候了。",
          "grounded_facts": [
            "乐娘在击鼓后为何云青斟酒， 何云青表现出醉态，口齿不清，最终栽倒， 乐娘扶住倒下的何云青，并与崔鸿至确认"
          ],
          "tags": [
            "操控何云青",
            "醉倒",
            "掌控时刻"
          ]
        },
        {
          "memory_id": "r005",
          "scene_id": "6",
          "scene_order": 7,
          "scene_title": "六 露緣",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_2cca9e779cbc1578"
          ],
          "source_memory_refs": [],
          "memory_text": "我含着泪把那条珠链从脖子上取下来，递到他面前，声音发抖地说：‘这是您送给我的订情物，现在还给您！’",
          "grounded_facts": [
            "乐娘在卧房中因何云青否认昨夜承诺而情绪激动， 她取下颈项上的珠链归还给何云青， 她说“这是您送给我的订情物，现在还给您！”时正在哭泣"
          ],
          "tags": [
            "被弃感",
            "归还信物",
            "哀怨",
            "情绪爆发"
          ]
        },
        {
          "memory_id": "r006",
          "scene_id": "6",
          "scene_order": 7,
          "scene_title": "六 露緣",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_2cca9e779cbc1578"
          ],
          "source_memory_refs": [],
          "memory_text": "我在荷花池边回头对他一笑，然后走过去靠进他怀里，轻轻说‘什么都不要再说了’，眼泪还在脸上，可心却软了。",
          "grounded_facts": [
            "乐娘在荷花池边等待何云青， 她回头展眸一笑，主动投入何云青怀中， 她以动作阻止何云青解释，选择沉默接纳"
          ],
          "tags": [
            "和解",
            "柔情",
            "身体亲近",
            "情感转折"
          ]
        },
        {
          "memory_id": "r007",
          "scene_id": "7",
          "scene_order": 8,
          "scene_title": "七 赶集",
          "importance": "supporting",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_6620429f26a1c050"
          ],
          "source_memory_refs": [],
          "memory_text": "我扶着妈妈坐起来，听见她喘得厉害，心里一紧，就说咱们别赶集了，就在这儿陪她吧，说完还看了云青一眼。",
          "grounded_facts": [
            "乐娘扶着生病的王妈妈坐起来。",
            "乐娘提到云青和崔鸿至想去买纸笔墨砚，自己提议顺便来看望母亲。",
            "乐娘主动提议不赶集，留下来陪伴母亲，并在说话时回头看了何云青。"
          ],
          "tags": [
            "家庭责任",
            "情感张力",
            "主动选择",
            "孝顺表现",
            "目光交流"
          ]
        },
        {
          "memory_id": "r008",
          "scene_id": "9",
          "scene_order": 10,
          "scene_title": "九 封印",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_5335cc90a93a72ba"
          ],
          "source_memory_refs": [],
          "memory_text": "我一把抓住云青的穴道，逼他跪在书案前，他挣扎不得，只能瘫软下去。我恨恨地说了句‘那我就小人做到底’，转身摔门出去，顺手把门锁上，他再也不能去找那个贱人了。",
          "grounded_facts": [
            "乐娘将文房四宝移到卧室，改变何云青抄经的位置。",
            "乐娘点住何云青的穴道，强制他跪在几前。",
            "乐娘说出‘好啊！我是小人……那我就小人做到底’后离开房间。",
            "乐娘离开时将房门拉上并上锁，限制何云青行动。"
          ],
          "tags": [
            "禁锢",
            "爆发",
            "控制",
            "嫉妒"
          ]
        },
        {
          "memory_id": "r009",
          "scene_id": "9",
          "scene_order": 10,
          "scene_title": "九 封印",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_5335cc90a93a72ba"
          ],
          "source_memory_refs": [],
          "memory_text": "我冲到山路上拦住云青，想把他拉回去，可那喇嘛突然出现，还威胁要让我永世不得超生。我假装服软，趁他不备甩出暗器，可葫芦喷出红烟，把我的招数吞了进去——我惊叫着，整个人跌进那片红色的迷雾里。",
          "grounded_facts": [
            "乐娘在山路上现身，试图强行带走何云青。",
            "喇嘛出现并警告乐娘不得再纠缠何云青。",
            "乐娘假意应承，随后突然施放暗器攻击喇嘛。",
            "喇嘛用木葫芦喷出红烟吞噬暗器，乐娘被击退，坠入红雾中。"
          ],
          "tags": [
            "对抗",
            "失败",
            "施法",
            "绝望"
          ]
        },
        {
          "memory_id": "r010",
          "scene_id": "10",
          "scene_order": 11,
          "scene_title": "十 故梦",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_11d1c7314bb194ff"
          ],
          "source_memory_refs": [],
          "memory_text": "我起身让开位置，不高兴地走进内厢，听着外面那新来的依云吹箫，那声音婉转得让人心烦，经略大人一个劲地夸她。",
          "grounded_facts": [
            "乐娘被韩经略要求让位给依云试奏箫艺",
            "乐娘不高兴地走入内厢",
            "依云演奏箫曲并获得韩经略高度赞赏"
          ],
          "tags": [
            "屈辱",
            "嫉妒",
            "被取代"
          ]
        },
        {
          "memory_id": "r011",
          "scene_id": "10",
          "scene_order": 11,
          "scene_title": "十 故梦",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_11d1c7314bb194ff"
          ],
          "source_memory_refs": [],
          "memory_text": "我在山谷边上，趁她转到我身边时，猛地一把将她推下深坑，她只来得及说半句‘你……’就摔了下去。",
          "grounded_facts": [
            "乐娘邀请依云到山谷练舞",
            "依云在山谷跳舞时旋转至乐娘身旁",
            "乐娘突然将依云推入深坑致其死亡"
          ],
          "tags": [
            "决断",
            "暴力",
            "复仇"
          ]
        },
        {
          "memory_id": "r012",
          "scene_id": "11",
          "scene_order": 12,
          "scene_title": "十一 缘了",
          "importance": "supporting",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_d5bf3169c3940908"
          ],
          "source_memory_refs": [],
          "memory_text": "我变成依云的样子，想让云青抄经，老张却来纠缠我。",
          "grounded_facts": [
            "乐娘变化成依云的模样出现在飘岩斋",
            "老张拦截了化身为依云的乐娘"
          ],
          "tags": [
            "变形",
            "阻拦",
            "飘岩斋"
          ]
        }
