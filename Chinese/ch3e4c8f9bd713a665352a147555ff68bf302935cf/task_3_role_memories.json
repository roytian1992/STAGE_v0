          ],
          "source_timeline_node_ids": [
            "v6tu_9237481cc8958ca4"
          ],
          "source_memory_refs": [],
          "memory_text": "我拦在崔叔叔和何公子面前，轻声说‘崔叔叔，您真的不进来呀？’，心跳得厉害，生怕他们就这样走了。",
          "grounded_facts": [
            "依云主动阻拦崔鸿至与何云青继续前行， 她以撒娇语气挽留崔鸿至， 她对二人是否进酒馆表现出关切与轻微不安"
          ],
          "tags": [
            "拦截挽留",
            "情感紧张",
            "主动引导"
          ]
        },
        {
          "memory_id": "r002",
          "scene_id": "8",
          "scene_order": 9,
          "scene_title": "八 恨晚",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
