      "memories": [
        {
          "memory_id": "r001",
          "scene_id": "4",
          "scene_order": 5,
          "scene_title": "四 惊艳",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_1e9f29aa2757a0e7"
          ],
          "source_memory_refs": [],
          "memory_text": "我穿着浅橙色的袍子走出来，王妈妈让我拜老师，我就跪下去叫了一声‘老师’，声音有点发颤，看见何公子慌得直摆手，还打翻了酒杯。",
          "grounded_facts": [
            "乐娘身穿浅橙色袍服从内室走出",
            "在王妈催促下向何云青跪拜行礼",
            "娇声称呼何云青为‘老师’",
            "何云青受惊起身避让并打翻酒杯"
          ],
          "tags": [
            "初次见面",
            "行礼",
            "视觉印象",
            "紧张"
          ]
        },
        {
          "memory_id": "r002",
          "scene_id": "4",
          "scene_order": 5,
          "scene_title": "四 惊艳",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_1e9f29aa2757a0e7"
          ],
          "source_memory_refs": [],
          "memory_text": "我蹲下帮他擦衣服，手帕轻轻擦过他的袍角，低头说‘对不起，何老师’，听见自己的声音像泉水一样清脆，他却慌得直说是我不好。",
          "grounded_facts": [
            "乐娘掏出手帕为何云青擦拭溅酒的袍服",
            "低头轻声道歉",
            "声音被描述为清脆如山谷流泉",
            "何云青回应时语无伦次"
          ],
          "tags": [
            "近距离接触",
            "声音印象",
            "柔声致歉",
            "情感波动"
          ]
        },
        {
          "memory_id": "r003",
          "scene_id": "5",
          "scene_order": 6,
          "scene_title": "五 战鼓",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_4355694e5592ad7b"
          ],
          "source_memory_refs": [],
          "memory_text": "我敲响那面毡鼓，鼓声低哑沉闷，像战鼓一样层层叠叠地压过去，那个喇嘛站都站不稳，最后只能转身逃走。",
          "grounded_facts": [
            "乐娘接过王妈递来的毡鼓并开始击鼓， 鼓声响起后喇嘛双脚浮动、神情凄凉，最终逃走， 乐娘目睹喇嘛被鼓声逼退的过程"
          ],
          "tags": [
            "鼓声击退喇嘛",
            "权力展示",
            "神秘力量"
          ]
        },
        {
          "memory_id": "r004",
          "scene_id": "5",
          "scene_order": 6,
          "scene_title": "五 战鼓",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_4355694e5592ad7b"
          ],
          "source_memory_refs": [],
          "memory_text": "我一边打鼓一边给他倒酒，他眼神迷乱，嘴里含糊地喊着好，最后头一歪就倒下了，我伸手扶住他，他知道是他该倒的时候了。",
          "grounded_facts": [
            "乐娘在击鼓后为何云青斟酒， 何云青表现出醉态，口齿不清，最终栽倒， 乐娘扶住倒下的何云青，并与崔鸿至确认"
          ],
          "tags": [
            "操控何云青",
            "醉倒",
            "掌控时刻"
          ]
        },
        {
          "memory_id": "r005",
          "scene_id": "6",
          "scene_order": 7,
          "scene_title": "六 露緣",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_2cca9e779cbc1578"
          ],
          "source_memory_refs": [],
          "memory_text": "我含着泪把那条珠链从脖子上取下来，递到他面前，声音发抖地说：‘这是您送给我的订情物，现在还给您！’",
          "grounded_facts": [
            "乐娘在卧房中因何云青否认昨夜承诺而情绪激动， 她取下颈项上的珠链归还给何云青， 她说“这是您送给我的订情物，现在还给您！”时正在哭泣"
          ],
          "tags": [
            "被弃感",
            "归还信物",
            "哀怨",
            "情绪爆发"
          ]
        },
        {
          "memory_id": "r006",
          "scene_id": "6",
          "scene_order": 7,
          "scene_title": "六 露緣",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_2cca9e779cbc1578"
          ],
          "source_memory_refs": [],
          "memory_text": "我在荷花池边回头对他一笑，然后走过去靠进他怀里，轻轻说‘什么都不要再说了’，眼泪还在脸上，可心却软了。",
          "grounded_facts": [
            "乐娘在荷花池边等待何云青， 她回头展眸一笑，主动投入何云青怀中， 她以动作阻止何云青解释，选择沉默接纳"
          ],
          "tags": [
            "和解",
            "柔情",
            "身体亲近",
            "情感转折"
          ]
        },
        {
          "memory_id": "r007",
          "scene_id": "7",
          "scene_order": 8,
          "scene_title": "七 赶集",
          "importance": "supporting",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_6620429f26a1c050"
          ],
          "source_memory_refs": [],
          "memory_text": "我扶着妈妈坐起来，听见她喘得厉害，心里一紧，就说咱们别赶集了，就在这儿陪她吧，说完还看了云青一眼。",
          "grounded_facts": [
            "乐娘扶着生病的王妈妈坐起来。",
            "乐娘提到云青和崔鸿至想去买纸笔墨砚，自己提议顺便来看望母亲。",
            "乐娘主动提议不赶集，留下来陪伴母亲，并在说话时回头看了何云青。"
          ],
          "tags": [
            "家庭责任",
            "情感张力",
            "主动选择",
            "孝顺表现",
            "目光交流"
          ]
        },
        {
          "memory_id": "r008",
          "scene_id": "9",
          "scene_order": 10,
          "scene_title": "九 封印",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_5335cc90a93a72ba"
          ],
          "source_memory_refs": [],
          "memory_text": "我一把抓住云青的穴道，逼他跪在书案前，他挣扎不得，只能瘫软下去。我恨恨地说了句‘那我就小人做到底’，转身摔门出去，顺手把门锁上，他再也不能去找那个贱人了。",
          "grounded_facts": [
            "乐娘将文房四宝移到卧室，改变何云青抄经的位置。",
            "乐娘点住何云青的穴道，强制他跪在几前。",
            "乐娘说出‘好啊！我是小人……那我就小人做到底’后离开房间。",
            "乐娘离开时将房门拉上并上锁，限制何云青行动。"
          ],
          "tags": [
            "禁锢",
            "爆发",
            "控制",
            "嫉妒"
          ]
        },
        {
          "memory_id": "r009",
          "scene_id": "9",
          "scene_order": 10,
          "scene_title": "九 封印",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_5335cc90a93a72ba"
          ],
          "source_memory_refs": [],
          "memory_text": "我冲到山路上拦住云青，想把他拉回去，可那喇嘛突然出现，还威胁要让我永世不得超生。我假装服软，趁他不备甩出暗器，可葫芦喷出红烟，把我的招数吞了进去——我惊叫着，整个人跌进那片红色的迷雾里。",
          "grounded_facts": [
            "乐娘在山路上现身，试图强行带走何云青。",
            "喇嘛出现并警告乐娘不得再纠缠何云青。",
            "乐娘假意应承，随后突然施放暗器攻击喇嘛。",
            "喇嘛用木葫芦喷出红烟吞噬暗器，乐娘被击退，坠入红雾中。"
          ],
          "tags": [
            "对抗",
            "失败",
            "施法",
            "绝望"
          ]
        },
        {
          "memory_id": "r010",
          "scene_id": "10",
          "scene_order": 11,
          "scene_title": "十 故梦",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_11d1c7314bb194ff"
          ],
          "source_memory_refs": [],
          "memory_text": "我起身让开位置，不高兴地走进内厢，听着外面那新来的依云吹箫，那声音婉转得让人心烦，经略大人一个劲地夸她。",
          "grounded_facts": [
            "乐娘被韩经略要求让位给依云试奏箫艺",
            "乐娘不高兴地走入内厢",
            "依云演奏箫曲并获得韩经略高度赞赏"
          ],
          "tags": [
            "屈辱",
            "嫉妒",
            "被取代"
          ]
        },
        {
          "memory_id": "r011",
          "scene_id": "10",
          "scene_order": 11,
          "scene_title": "十 故梦",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_11d1c7314bb194ff"
          ],
          "source_memory_refs": [],
          "memory_text": "我在山谷边上，趁她转到我身边时，猛地一把将她推下深坑，她只来得及说半句‘你……’就摔了下去。",
          "grounded_facts": [
            "乐娘邀请依云到山谷练舞",
            "依云在山谷跳舞时旋转至乐娘身旁",
            "乐娘突然将依云推入深坑致其死亡"
          ],
          "tags": [
            "决断",
            "暴力",
            "复仇"
          ]
        },
        {
          "memory_id": "r012",
          "scene_id": "11",
          "scene_order": 12,
          "scene_title": "十一 缘了",
          "importance": "supporting",
          "identity_phase": null,
          "source_roles": [
            "乐娘"
          ],
          "source_timeline_node_ids": [
            "v6tu_d5bf3169c3940908"
          ],
          "source_memory_refs": [],
          "memory_text": "我变成依云的样子，想让云青抄经，老张却来纠缠我。",
          "grounded_facts": [
            "乐娘变化成依云的模样出现在飘岩斋",
            "老张拦截了化身为依云的乐娘"
          ],
          "tags": [
            "变形",
            "阻拦",
            "飘岩斋"
          ]
        }
      ]
    },
    {
      "character_name": "何云青",
      "aliases": [
        "何云青"
      ],
      "memory_count": 18,
      "source_type": "memory_salvaged_20260418",
      "memories": [
        {
          "memory_id": "r001",
          "scene_id": "1",
          "scene_order": 2,
          "scene_title": "一 受命",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "何云青"
          ],
          "source_timeline_node_ids": [
            "v6tu_b1fcee5197aa6d9a"
          ],
          "source_memory_refs": [],
          "memory_text": "大师父把推荐信交给我，我看到信封上写着‘崔鸿至’。他说这是经略府的参军，信里还有一张银票，够我用的了。",
          "grounded_facts": [
            "何云青从大师父手中接过一封推荐信。",
            "信封上写着‘崔鸿至’的名字。",
            "大师父提到信中附有一张银票，足够何云青使用。",
            "崔鸿至是经略府的参军，与大师父有一年多未见。"
          ],
          "tags": []
        },
        {
          "memory_id": "r002",
          "scene_id": "2",
          "scene_order": 3,
          "scene_title": "二 远涉",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "何云青"
          ],
          "source_timeline_node_ids": [
            "v6tu_f103ec6a04521798"
          ],
          "source_memory_refs": [],
          "memory_text": "我正走着，忽然看见一位白衣少女站在小河边吹箫，那箫声凄美得像是从水底浮上来的，我看得呆住，脚步不由自主跟着声音往前赶，可一眨眼她就不见了，连影子都消在雾里。",
          "grounded_facts": [
            "何云青在山径行走时目睹白衣少女在小河左侧吹箫",
            "箫声优美凄凉，使何云青陷入恍惚状态",
            "他追随箫声前行，少女随即消失",
            "之后在古庙前再次见到同一少女，靠近时她再度消散"
          ],
          "tags": [
            "幻象",
            "箫声",
            "白衣少女",
            "迷失",
            "恐惧"
          ]
        },
        {
          "memory_id": "r003",
          "scene_id": "2",
          "scene_order": 3,
          "scene_title": "二 远涉",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "何云青"
          ],
          "source_timeline_node_ids": [
            "v6tu_f103ec6a04521798"
          ],
          "source_memory_refs": [],
          "memory_text": "那个跛子突然掐住我的脖子，我吓得脸色发白，拼命挣扎，直到一个穿锦袍的人喊他放手——后来才知道他是崔鸿至，还告诉我韩将军殉国、驻军全军覆没，我抬头看着那破败的屯堡，心里一阵发凉。",
          "grounded_facts": [
            "老跛子突然袭击何云青，掐住其脖颈",
            "中年文士崔鸿至出现并喝止老跛子",
            "何云青向崔鸿至询问秦凤路经略府位置及驻军情况",
            "崔鸿至告知西夏倾巢而出，驻军几乎全军覆没，韩将军殉国",
            "何云青目睹残破屯堡与寒鸦，情绪受冲击"
          ],
          "tags": [
            "袭击",
            "崔鸿至",
            "战败",
            "韩将军殉国",
            "震惊"
          ]
        },
        {
          "memory_id": "r004",
          "scene_id": "3",
          "scene_order": 4,
          "scene_title": "三 止泊",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "何云青"
          ],
          "source_timeline_node_ids": [
            "v6tu_8d6e8ef5c93d3b66"
          ],
          "source_memory_refs": [],
          "memory_text": "我走进那阁楼卧房时，桌上一根未燃的白烛，旁边堆着空的瓮碗，屋里又暗，心里突然泛起一阵冷森森的感觉，虽然只是一下子，可那寒意像是从背脊爬上来似的。",
          "grounded_facts": [
            "何云青进入阁楼卧房，看到桌上有一根未燃的白烛和空的瓮碗。",
            "房间光线阴暗，使他内心产生冷森森的感觉。",
            "这种感觉出现后很快消失。"
          ],
          "tags": [
            "感官记忆",
            "环境感知",
            "情绪反应"
          ]
        },
        {
          "memory_id": "r005",
          "scene_id": "3",
          "scene_order": 4,
          "scene_title": "三 止泊",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "何云青"
          ],
          "source_timeline_node_ids": [
            "v6tu_8d6e8ef5c93d3b66"
          ],
          "source_memory_refs": [],
          "memory_text": "我跟着小青走夜路去吃饭，天黑了，林子发暗，我看见一团黄影从林中闪过，惊叫出声，问她怕不怕，她回头一笑，说那是个番僧，别怕。",
          "grounded_facts": [
            "何云青由小青引领走山间小径去吃饭。",
            "黄昏时分，周围渐暗，林中景象诡谲。",
            "何云青看到黑林中闪过一团黄影，因而惊叫。",
            "他问小青一个人走这条路是否害怕。",
            "小青回应称黄影是番僧，并安抚他别怕。"
          ],
          "tags": [
            "夜路",
            "山间小径",
            "小青",
            "黄影",
            "番僧",
            "恐惧",
            "对话"
          ]
        },
        {
          "memory_id": "r006",
          "scene_id": "4",
          "scene_order": 5,
          "scene_title": "四 惊艳",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "何云青"
          ],
          "source_timeline_node_ids": [
            "v6tu_3dea3361fbe792ef"
          ],
          "source_memory_refs": [],
          "memory_text": "我看见她走出来，穿浅橙色袍服，脸像满月，眼睛像水一样亮，我一下子怔住了，嘴都合不拢，心跳得厉害，手都不知道往哪儿放。",
          "grounded_facts": [
            "何云青在乐娘出现时表现出震惊和呆滞， 乐娘穿着浅橙色袍服，容貌被细致描写， 何云青因乐娘的美貌而产生强烈情绪和身体反应"
          ],
          "tags": [
            "初见震撼",
            "视觉冲击",
            "情绪失控",
            "身体僵直"
          ]
        },
        {
          "memory_id": "r007",
          "scene_id": "4",
          "scene_order": 5,
          "scene_title": "四 惊艳",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "何云青"
          ],
          "source_timeline_node_ids": [
            "v6tu_3dea3361fbe792ef"
          ],
          "source_memory_refs": [],
          "memory_text": "她端起酒杯敬我，眼波一转就笑了，我心跳得更厉害，想推辞却说不出完整话，后来一杯接一杯地喝，头开始发晕，眼前的人影都模糊了。",
          "grounded_facts": [
            "乐娘向何云青敬酒并眉目传情， 何云青试图拒绝但最终饮酒， 他因饮酒而醉眼朦胧、神志不清"
          ],
          "tags": [
            "饮酒失控",
            "社交压迫",
            "感官模糊",
            "心理眩晕"
          ]
        },
        {
          "memory_id": "r008",
          "scene_id": "5",
          "scene_order": 6,
          "scene_title": "五 战鼓",
          "importance": "supporting",
          "identity_phase": null,
          "source_roles": [
            "何云青"
          ],
          "source_timeline_node_ids": [
            "v6tu_1244d7195d22bbd5"
          ],
          "source_memory_refs": [],
          "memory_text": "那鼓声一开始低沉，像秋风拂面，可听着听着，就变得急促起来，像战鼓、像雷声一层层压过来，我整个人都晕晕乎乎的，仿佛在风浪里的船上，忍不住喊出‘好极了’。",
          "grounded_facts": [
            "何云青听到乐娘打鼓，鼓声由缓至急，产生强烈听觉冲击。",
            "他在鼓声中感到晕眩、陶醉，失去空间感，发出赞叹。",
            "鼓声被描述为如浪涛、战鼓、雷声，具有迷幻效果。"
          ],
          "tags": [
            "听觉记忆",
            "感官沉浸",
            "情绪波动"
          ]
        },
        {
          "memory_id": "r009",
          "scene_id": "5",
          "scene_order": 6,
          "scene_title": "五 战鼓",
          "importance": "supporting",
          "identity_phase": null,
          "source_roles": [
            "何云青"
          ],
          "source_timeline_node_ids": [
            "v6tu_1244d7195d22bbd5"
          ],
          "source_memory_refs": [],
          "memory_text": "我明明说‘我不行了’，可乐娘还是给我倒酒，崔叔叔一直劝，我迷迷糊糊地举着杯子，嘴里说着‘好，喝，好，喝……’，然后眼前一黑，头一晃就倒了下去，最后是她扶住我的。",
          "grounded_facts": [
            "何云青明确表达无法继续饮酒。",
            "乐娘在他杯中斟酒，崔鸿至持续劝酒。",
            "他口齿不清地重复话语，随后昏倒，被乐娘扶住。"
          ],
          "tags": [
            "身体失控",
            "意识模糊",
            "被动顺从"
          ]
        },
        {
          "memory_id": "r010",
          "scene_id": "6",
          "scene_order": 7,
          "scene_title": "六 露緣",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "何云青"
          ],
          "source_timeline_node_ids": [
            "v6tu_6106a51f3c8f2231"
          ],
          "source_memory_refs": [],
          "memory_text": "我醒来时头还昏沉着，看见乐娘坐在镜台前梳头，脸上泛着红晕，像是沾着露水的桃花，我心跳了一下，才意识到她一整夜都没回去。",
          "grounded_facts": [
            "何云青醒来时看到乐娘在房中梳妆。",
            "乐娘脸颊泛红，发上有露珠，形象被比作沾露桃花。",
            "何云青意识到乐娘整夜未归，感到局促和震惊。"
          ],
          "tags": [
            "感官记忆",
            "情绪觉醒",
            "环境细节"
          ]
        },
        {
          "memory_id": "r011",
          "scene_id": "6",
          "scene_order": 7,
          "scene_title": "六 露緣",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "何云青"
          ],
          "source_timeline_node_ids": [
            "v6tu_6106a51f3c8f2231"
          ],
          "source_memory_refs": [],
          "memory_text": "我远远看着她站在荷花池边，白袍被风吹动，背影和山水融成一幅画，那一刻我忽然觉得，也许这就是缘，心也慢慢静了下来。",
          "grounded_facts": [
            "何云青看到乐娘站在荷花池边，背影与自然景色融为一体。",
            "风吹动乐娘的白袍，周围有荷、叶、山、松，景象如水墨画。",
            "何云青内心产生一种宿命感，称其为‘缘’，情绪由混乱转为接受。"
          ],
          "tags": [
            "视觉印象",
            "情感转折",
            "自然象征"
          ]
        },
        {
          "memory_id": "r012",
          "scene_id": "7",
          "scene_order": 8,
          "scene_title": "七 赶集",
          "importance": "supporting",
          "identity_phase": null,
          "source_roles": [
            "何云青"
          ],
          "source_timeline_node_ids": [
            "v6tu_cdbead391a917e3a"
          ],
          "source_memory_refs": [],
          "memory_text": "我站在岳母床前，听见乐娘说‘咱们不用赶集了，就在这里陪陪妈妈吧’，我张了张嘴，只说出‘我的东西……’，心里又想走又舍不得留，腿像生了根似的动不了。",
          "grounded_facts": [
            "何云青在岳母生病时前来探视。",
            "乐娘提议留在家中陪伴母亲，不再赶集。",
            "何云青表现出犹豫，话语断续，仅说出‘我的东西……’。",
            "他最终在岳母劝说下决定离开，但情绪上充满挣扎。"
          ],
          "tags": [
            "犹豫",
            "情感冲突",
            "家庭责任",
            "言语迟疑"
          ]
        },
        {
          "memory_id": "r013",
          "scene_id": "8",
          "scene_order": 9,
          "scene_title": "八 恨晚",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "何云青"
          ],
          "source_timeline_node_ids": [
            "v6tu_1fc6e74ccf945a93"
          ],
          "source_memory_refs": [],
          "memory_text": "我望着她吹箫的样子，脸颊微红，声音像流水一样，忽然就呆住了，仿佛之前在山里见过她，可又说不清是在哪儿。",
          "grounded_facts": [
            "何云青看到依云吹箫时神情恍惚，陷入初入山中的记忆片段， 他定定望着依云，注意到她脸颊微红、吐音如流水行云的细节， 他内心产生熟悉感，说出“我好象在那儿见到过你”，并坚持自己曾多次看见她"
          ],
          "tags": [
            "情感吸引",
            "记忆闪回",
            "感官印象",
            "迟疑",
            "情绪外露"
          ]
        },
        {
          "memory_id": "r014",
          "scene_id": "8",
          "scene_order": 9,
          "scene_title": "八 恨晚",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "何云青"
          ],
          "source_timeline_node_ids": [
            "v6tu_1fc6e74ccf945a93"
          ],
          "source_memory_refs": [],
          "memory_text": "她跌进我怀里说‘我怕’，我抱着她轻声说‘不怕’，她挣开后见四下无人，又重新靠进我怀里，那一刻我忘了乐娘是谁。",
          "grounded_facts": [
            "依云从山丘上下来时跌入何云青怀中，说出“我怕”， 何云青抱住她并连续轻声安慰“不怕！不怕！不怕……”， 依云先挣脱后见四周无人又主动偎进他怀里，两人紧紧拥抱， 何云青在这一瞬间忘记乐娘是自己的妻子，被依云的影像完全占据"
          ],
          "tags": [
            "身体接触",
            "情感升温",
            "内心动摇",
            "忠诚冲突",
            "紧张",
            "挂心"
          ]
        },
        {
          "memory_id": "r015",
          "scene_id": "9",
          "scene_order": 10,
          "scene_title": "九 封印",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "何云青"
          ],
          "source_timeline_node_ids": [
            "v6tu_749ff64cab0a09b4"
          ],
          "source_memory_refs": [],
          "memory_text": "我正要进内室，乐娘突然厉声喝止，身形一晃就冲到我面前，伸手一点，我的双腿瞬间发麻，动弹不得，扑通跪倒在她跟前。我惊恐地喊着：‘我的腿！我的腿不对了！乐娘！’",
          "grounded_facts": [
            "乐娘突然点住何云青的穴道",
            "何云青双腿麻痹，跪倒在地",
            "何云青当场惊骇并呼喊乐娘"
          ],
          "tags": [
            "身体失控",
            "突然袭击",
            "恐惧反应"
          ]
        },
        {
          "memory_id": "r016",
          "scene_id": "9",
          "scene_order": 10,
          "scene_title": "九 封印",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "何云青"
          ],
          "source_timeline_node_ids": [
            "v6tu_749ff64cab0a09b4"
          ],
          "source_memory_refs": [],
          "memory_text": "依云把我从屋里带出来，帮我解开穴道，然后正色告诉我：‘乐娘是厉鬼！’我听见这两个字，脑子嗡的一下，全身发冷，只喊出一个‘啊？！’",
          "grounded_facts": [
            "依云解开何云青的穴道",
            "依云告知乐娘是厉鬼",
            "何云青震惊并发出惊叫"
          ],
          "tags": [
            "真相揭露",
            "心理冲击",
            "认知颠覆"
          ]
        },
        {
          "memory_id": "r017",
          "scene_id": "11",
          "scene_order": 12,
          "scene_title": "十一 缘了",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "何云青"
          ],
          "source_timeline_node_ids": [
            "v6tu_e362ae72225af747"
          ],
          "source_memory_refs": [],
          "memory_text": "我紧紧抓着经书和念珠从屋里冲出来，风刮得脸生疼，青山乱了步调，松树像鬼影一样狂舞，我根本不敢回头，只知道拼命往飘岩斋跑。",
          "grounded_facts": [
            "何云青在狂风中携带经书和念珠逃离原居所， 狂风导致屋内狼藉、纸笔乱飞、门户乱响， 他面颊被风打得作疼，视觉中青山和松林呈现混乱、恐怖的意象， 他未观察四周，直接奔向飘岩斋"
          ],
          "tags": [
            "恐惧",
            "逃亡",
            "感官冲击",
            "环境异变"
          ]
        },
        {
          "memory_id": "r018",
          "scene_id": "11",
          "scene_order": 12,
          "scene_title": "十一 缘了",
          "importance": "core",
          "identity_phase": null,
          "source_roles": [
            "何云青"
          ],
          "source_timeline_node_ids": [
            "v6tu_e362ae72225af747"
          ],
          "source_memory_refs": [],
          "memory_text": "两个一模一样的依云站在屋里，一个让我吃灵芝，一个让我快逃，老张发狂地掐人，我拿着念珠不知该信谁；最后喇嘛来了，我含着泪把念珠扔出去，看见依云在烟雾里扭曲、化成灰烬。",
          "grounded_facts": [
            "何云青目睹两个依云同时出现并发出矛盾指令， 老张攻击其中一名依云，屋内陷入混乱， 他在喇嘛指引下使用密腊念珠投向两个依云， 念珠引发巨响与白烟，依云与乐娘幻影在烟中扭曲后化为灰烬， 他目睹全过程并流露出强烈哀戚"
          ],
          "tags": [
            "身份混淆",
            "情感撕裂",
            "决断时刻",
            "超自然对峙",
            "悲痛觉悟"
          ]
        }
      ]
    },
    {
      "character_name": "依云",
      "aliases": [
        "依云"
      ],
      "memory_count": 8,
      "source_type": "memory_salvaged_20260418",
      "memories": [
        {
          "memory_id": "r001",
